# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dclaw_crm
APP_ENV=dev
DEBUG=true

# AI Flow Copilot (P0.1) — provider order: auto | ollama | openrouter | heuristic
COPILOT_PROVIDER=auto
